# Symbols use Yahoo Finance notation. Examples: AAPL, MSFT, PTT.BK, CPALL.BK
SYMBOLS=AAPL,MSFT
INTERVAL=1h
LOOKBACK_DAYS=365
POLL_SECONDS=300
# Confidence sizing: 70-79%=5%, 80-89%=10%, 90-95%=15%, >95%=20% (capped).
MIN_WIN_PROBABILITY=0.70
MIN_SIGNAL_SAMPLES=30
SIGNAL_HORIZON_BARS=20
# Expected IBKR commission for both entry and exit. Reconcile against What-If.
ESTIMATED_ROUND_TRIP_COMMISSION=2.01
WHAT_IF_COMMISSION_BUFFER_PCT=0.10
# Round-trip estimates as a fraction of entry notional (0.001 = 0.10%).
ESTIMATED_EXCHANGE_FEE_RATE=0
ESTIMATED_FX_COST_RATE=0
# Tax menu: only 0, 0.10, 0.15, or 0.20 are accepted.
TAX_RATE=0
# BUY only when expected net profit is strictly greater than this x trading cost.
MIN_NET_PROFIT_COST_MULTIPLE=3
MIN_VOLUME_RATIO=1.0
MIN_ATR_PCT=0.005
MAX_ATR_PCT=0.04
# Dedicated one-share connectivity test symbol; never changes production SYMBOLS.
PAPER_TEST_SYMBOL=T
STARTING_CASH=200
MAX_ORDER_NOTIONAL=50
MAX_TOTAL_EXPOSURE=150
MAX_DAILY_LOSS=20
MAX_DAILY_LOSS_PCT=0.02
MAX_ORDERS_PER_DAY=10
MAX_CONCURRENT_POSITIONS=3
MAX_CONSECUTIVE_LOSSES=3
MAX_CONSECUTIVE_CYCLE_ERRORS=3
MIN_PAPER_CLOSED_TRADES_FOR_LIVE=30
MIN_PAPER_WIN_RATE_FOR_LIVE=0.50
MIN_PAPER_PROFIT_FACTOR_FOR_LIVE=1.20
MIN_PAPER_TRADING_DAYS_FOR_LIVE=20
MAX_PAPER_DRAWDOWN_PCT_FOR_LIVE=0.10
STOP_LOSS_PCT=0.02
TRAILING_STOP_PCT=0.015
# Fixed 10% profit target (equal min/max disables the ATR range).
TAKE_PROFIT_PCT=0.10
TAKE_PROFIT_MAX_PCT=0.10
TAKE_PROFIT_ATR_MULTIPLIER=3.0
COOLDOWN_MINUTES=60
KILL_SWITCH=true

# local = simulated fills stored in SQL Server; alpaca = Alpaca paper/live
BROKER=local
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Interactive Brokers via TWS or IB Gateway. Start with a paper account.
# TWS: paper 7497 / live 7496; Gateway: paper 4002 / live 4001.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=7
IBKR_ACCOUNT=
IBKR_EXCHANGE=SMART
IBKR_CURRENCY=USD
IBKR_PRIMARY_EXCHANGE=
IBKR_PAPER=true
IBKR_READ_ONLY=true
IBKR_ORDER_TIMEOUT_SECONDS=30
# 1=live, 2=frozen, 3=delayed, 4=delayed-frozen
IBKR_MARKET_DATA_TYPE=3
MAX_MARKET_DATA_AGE_SECONDS=120
WATCHDOG_STALE_SECONDS=900
LIVE_PREFLIGHT_VALID_HOURS=24
IBKR_NATIVE_BRACKET=true
IBKR_ENTRY_LIMIT_OFFSET_PCT=0.002
LIVE_TRADING_CONFIRM=
# Live-only acknowledgements after verifying tax treatment and actual IBKR statements/What-If.
LIVE_TAX_CONFIRM=
LIVE_COST_MODEL_CONFIRM=
# Optional defense-in-depth: refuse to run under any other OS account.
ALLOWED_OS_USER=

LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=
LINE_CHANNEL_SECRET=
# Must be one LINE user ID beginning with U. Group/room IDs are rejected.
LINE_CONTROL_USER_ID=
LINE_CONTROLLER_HOST=127.0.0.1
LINE_CONTROLLER_PORT=8080
NGROK_AUTHTOKEN=
NGROK_PATH=ngrok
NGROK_UPSTREAM=http://127.0.0.1:8080
# Daily LINE summary. DAILY_PROFIT_TARGET=0 hides the target from the message.
DAILY_REPORT_TIME=23:59
DAILY_REPORT_TIMEZONE=Asia/Bangkok
DAILY_REPORT_CURRENCY=USD
DAILY_PROFIT_TARGET=0
# Same style as Invoice (Windows/SSMS integrated authentication)
DATABASE_URL=sqlserver://YOUR_SERVER;database=TradingBot;integratedSecurity=true;trustServerCertificate=true
# Docker/Linux should normally use SQL login instead:
# DATABASE_URL=sqlserver://YOUR_SERVER;database=TradingBot;user=sa;password=CHANGE_ME;trustServerCertificate=true
LOG_LEVEL=INFO
