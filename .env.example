# Symbols use Yahoo Finance notation. Examples: AAPL, MSFT, PTT.BK, CPALL.BK
SYMBOLS=AAPL,MSFT
INTERVAL=1h
LOOKBACK_DAYS=365
POLL_SECONDS=300
MIN_WIN_PROBABILITY=0.70
MIN_SIGNAL_SAMPLES=30
STARTING_CASH=100000
RISK_PER_TRADE=0.005
MAX_POSITION_PCT=0.10
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
COOLDOWN_MINUTES=60
KILL_SWITCH=false

# local = simulated fills stored in SQL Server; alpaca = Alpaca paper/live
BROKER=local
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=
# Same style as Invoice (Windows/SSMS integrated authentication)
DATABASE_URL=sqlserver://YOUR_SERVER;database=TradingBot;integratedSecurity=true;trustServerCertificate=true
# Docker/Linux should normally use SQL login instead:
# DATABASE_URL=sqlserver://YOUR_SERVER;database=TradingBot;user=sa;password=CHANGE_ME;trustServerCertificate=true
LOG_LEVEL=INFO
